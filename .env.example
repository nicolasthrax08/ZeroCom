# Server
PORT=3001
RESEARCH_PORT=3002
NODE_ENV=development

# Redis (required for OTP + rate limit)
REDIS_URL=redis://localhost:6379

# JWT (REQUIRED — generate a random 64-char hex string for production)
JWT_SECRET=dev-only-change-me-in-production-use-64-random-hex-chars

# CORS (comma-separated origins, * for all)
CORS_ORIGINS=*
